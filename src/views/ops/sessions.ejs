<h1>Sessions</h1>
<p class="muted">
  Active agent sessions reported by the <code>sessions_list</code> tool. Read-only — v1
  surfaces key, kind, channel, last message preview, timestamps, and a deep-link
  to the on-disk JSONL transcript (when accessible).
</p>

<%
  function stateBadge(state) {
    if (state === 'ok') return '<span class="badge ok">ok</span>';
    if (state === 'unreachable') return '<span class="badge warn">sessions_list unreachable</span>';
    if (state === 'invalid_json') return '<span class="badge warn">invalid json</span>';
    if (state === 'spawn_failed') return '<span class="badge warn">spawn failed</span>';
    return '<span class="badge muted">' + state + '</span>';
  }
%>

<div class="meta">
  <p>
    State: <%- stateBadge(view.state) %>
    <% if (view.binPath) { %>
      · binary: <code><%= view.binPath %></code>
    <% } else { %>
      · binary: <code>sessions_list</code> (not resolved; check OPENCLAW_BIN)
    <% } %>
  </p>
  <% if (view.error) { %>
    <p class="muted"><%= view.error %></p>
  <% } %>
</div>

<% if (view.state === 'ok' && view.sessions.length === 0) { %>
  <div class="flash">No sessions reported.</div>
<% } else if (view.state === 'ok') { %>
  <table class="sessions">
    <thead>
      <tr>
        <th>key</th>
        <th>kind</th>
        <th>channel</th>
        <th>last message</th>
        <th>started</th>
        <th>updated</th>
        <th>transcript</th>
      </tr>
    </thead>
    <tbody>
      <% for (const s of view.sessions) { %>
        <tr>
          <td><code><%= s.key %></code></td>
          <td><%= s.kind %></td>
          <td><%= s.channel %></td>
          <td class="last-msg"><%= (s.lastMessage && s.lastMessage !== '') ? s.lastMessage : '\u2014' %></td>
          <td><%= (s.startedAt) ? s.startedAt : '\u2014' %></td>
          <td><%= (s.updatedAt) ? s.updatedAt : '\u2014' %></td>
          <td class="transcript">
            <% if (s.transcriptPath) { %>
              <code class="path" title="<%= s.transcriptPath %>"><%= s.transcriptPath %></code>
              <% if (s.deepLink) { %>
                <a href="<%= s.deepLink %>" class="deeplink" target="_blank" rel="noopener noreferrer"
                   title="Open transcript in file:// (won't open in browser sandbox)">open</a>
              <% } else { %>
                <span class="muted">(file not on disk)</span>
              <% } %>
            <% } else { %>
              <span class="muted">—</span>
            <% } %>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
<% } %>

<style>
  .meta { display: flex; gap: 1rem; align-items: center; flex-wrap: wrap; }
  table.sessions { border-collapse: collapse; width: 100%; }
  table.sessions th, table.sessions td {
    border-bottom: 1px solid #e1e6e9; padding: 0.4rem 0.6rem;
    vertical-align: top; text-align: left;
  }
  table.sessions th { background: #f4f7f9; font-size: 0.85rem; }
  table.sessions td.last-msg { max-width: 320px; word-break: break-word; }
  table.sessions td.transcript code.path {
    display: inline-block; max-width: 360px; overflow: hidden;
    text-overflow: ellipsis; white-space: nowrap; vertical-align: middle;
  }
  table.sessions td.transcript .deeplink {
    margin-left: 0.5rem; font-size: 0.85rem;
  }
  .muted { color: #6a7d83; font-size: 0.85rem; margin: 0.2rem 0 0.6rem 0; }
  .badge { display: inline-block; padding: 0 0.4rem; border-radius: 3px; font-size: 0.75rem; vertical-align: middle; }
  .badge.ok { background: #d4edda; color: #155724; }
  .badge.muted { background: #e9ecef; color: #495057; }
  .badge.warn { background: #fff3cd; color: #856404; }
</style>