<h1>RAG · Ingest</h1>
<p class="muted">
  Add files (.md, .txt, .json, .yaml) or paste text. The default chunk size is
  800 chars with 200 char overlap. The dashboard never persists the file body;
  it streams to <code>bin/rag ingest-file</code> via a temp file in
  <code>runtime/tmp/ingest/&lt;uuid&gt;-name</code> and unlinks immediately. Every
  successful or failed ingest writes an audit log entry.
</p>

<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="flash"><%= flash %></div>
<% } %>

<% if (typeof importMutationEnabled !== 'undefined' && !importMutationEnabled) { %>
  <div class="error">
    <strong>Mutations are disabled.</strong>
    Set <code>IMPORT_MUTATION_ENABLED=true</code> in the dashboard's env
    to enable this route. See Risks #5, #8.
  </div>
<% } else { %>
  <%
    function stateBadge(state) {
      if (state === 'ok') return '<span class="badge ok">ok</span>';
      if (state === 'rag_unavailable') return '<span class="badge warn">RAG unavailable</span>';
      if (state === 'unreachable') return '<span class="badge warn">unreachable</span>';
      if (state === 'invalid_json') return '<span class="badge warn">invalid json</span>';
      if (state === 'spawn_failed') return '<span class="badge warn">spawn failed</span>';
      if (state === 'unsupported_media') return '<span class="badge warn">unsupported media</span>';
      if (state === 'payload_too_large') return '<span class="badge warn">payload too large</span>';
      if (state === 'invalid_input') return '<span class="badge warn">invalid input</span>';
      return '<span class="badge muted">' + state + '</span>';
    }
  %>

  <form method="post" action="/rag/ingest" enctype="multipart/form-data" class="form">
    <%- include('../partials/csrf-input') %>
    <h2>Upload a file</h2>
    <label for="file">File (max 10 MiB; .md / .txt / .json / .yaml / .yml)</label>
    <input type="file" id="file" name="file" accept=".md,.txt,.json,.yaml,.yml" required />
    <label for="source-upload">Source tag</label>
    <input
      type="text"
      id="source-upload"
      name="source"
      placeholder="meeting-2026-07-05"
      maxlength="128"
    />
    <button type="submit">Upload &amp; ingest</button>
  </form>

  <hr />

  <form method="post" action="/rag/ingest/text" class="form">
    <%- include('../partials/csrf-input') %>
    <h2>Paste text</h2>
    <label for="text">Text body (max 1 MiB)</label>
    <textarea
      id="text"
      name="text"
      rows="8"
      maxlength="1048576"
      required
    ></textarea>
    <label for="source-text">Source tag</label>
    <input
      type="text"
      id="source-text"
      name="source"
      placeholder="manual-note"
      maxlength="128"
    />
    <button type="submit">Ingest text</button>
  </form>

  <% if (typeof view !== 'undefined' && view.error) { %>
    <div class="error">
      <%- stateBadge(view.state) %>
      <%= view.error %>
    </div>
  <% } %>
<% } %>

<style>
  .form { display: flex; flex-direction: column; gap: 0.4rem; max-width: 720px; }
  .form input[type=text], .form input[type=file], .form textarea { padding: 0.4rem 0.5rem; font-family: ui-monospace, monospace; }
  .form textarea { font-size: 0.85rem; }
  .form button[type=submit] { width: max-content; padding: 0.5rem 0.9rem; }
  hr { margin: 1.2rem 0; border: none; border-top: 1px solid #e1e6e9; }
  .muted { color: #6a7d83; font-size: 0.85rem; margin: 0 0 0.6rem 0; }
  .badge { display: inline-block; padding: 0 0.4rem; border-radius: 3px; font-size: 0.75rem; vertical-align: middle; }
  .badge.ok { background: #d4edda; color: #155724; }
  .badge.muted { background: #e9ecef; color: #495057; }
  .badge.warn { background: #fff3cd; color: #856404; }
</style>
