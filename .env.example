# skill-admin-dashboard — environment
# Copy to .env and fill in. NEVER commit .env.

# --- Bind address (v1: loopback only) ---
HOST=127.0.0.1
PORT=4320

# --- Local token auth (HTTP basic fallback for protected mutating routes) ---
# Set LOCAL_API_TOKEN to a long random string. `make init` auto-generates one.
LOCAL_TOKEN_AUTH_REQUIRED=true
# LOCAL_API_TOKEN=<set-a-long-random-local-token>

# --- Safety defaults (mutating routes require explicit opt-in) ---
# All three default to the safe/closed state.
READONLY_MODE=true
APPROVAL_ACTIONS_ENABLED=false
IMPORT_MUTATION_ENABLED=false

# --- Optional UI display timezone (UTC, Asia/Shanghai, Europe/Paris, ...) ---
UI_TIMEZONE=UTC

# --- OpenClaw / skill-secret env (inherited by `bin/secret` subprocess) ---
# SKILL_SECRET_KMS_BACKEND=
# SKILL_SECRET_KMS_PROJECT_URL=
# SKILL_SECRET_KMS_API_BLOB=
# SKILL_SECRET_PASSPHRASE=

# --- OpenClaw tool paths (cron, sessions_list, opencode) ---
# OPENCLAW_BIN=/usr/local/bin:/usr/bin
